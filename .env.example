# Public site URL (must include trailing slash)
SEARXNG_BASE_URL=https://search.example.com/

# Generate with: openssl rand -hex 32
SEARXNG_SECRET=change-me-64-hex-chars

# Public usage with no rate-limiter
SEARXNG_PUBLIC_INSTANCE=true
SEARXNG_LIMITER=false
SEARXNG_IMAGE_PROXY=true
SEARXNG_METHOD=GET
SEARXNG_DEBUG=false

# Caddy reverse proxy / TLS
DOMAIN=search.example.com
ACME_EMAIL=you@example.com

# Protect settings-like pages (/preferences, /stats, /config)
ADMIN_USER=admin
# Generate hash with:
# docker run --rm caddy:2-alpine caddy hash-password --plaintext "your-strong-password"
ADMIN_PASSWORD_HASH=change-me-bcrypt-hash