# For cloud app/pod env var setup (no docker-compose required)
# Public URL must end with '/'
SEARXNG_BASE_URL=https://search.example.com/

# Generate with: openssl rand -hex 32
SEARXNG_SECRET=change-me-64-hex-chars

# Public instance + no built-in rate limiter
SEARXNG_PUBLIC_INSTANCE=true
SEARXNG_LIMITER=false
SEARXNG_IMAGE_PROXY=true
SEARXNG_METHOD=GET
SEARXNG_DEBUG=false
